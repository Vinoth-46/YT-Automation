# ── HuggingFace (free) ─────────────────────────────────────────────────────
# Sign up free at https://huggingface.co → Settings → Access Tokens → New token
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram Bot (free) ────────────────────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → copy token
# 2. Open @userinfobot → get your numeric chat ID
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=987654321

# ── Pexels (free) — construction B-roll backgrounds ────────────────────────
# Sign up at https://www.pexels.com/api/  (free, unlimited)
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SadTalker path ─────────────────────────────────────────────────────────
# After cloning: git clone https://github.com/OpenTalker/SadTalker.git
SADTALKER_DIR=/home/youruser/SadTalker

# ── Avatar photo ───────────────────────────────────────────────────────────
# Download a realistic face from https://thispersondoesnotexist.com
# Save as JPG (512×512 minimum, front-facing, neutral background)
AVATAR_PHOTO=data/avatars/presenter.jpg

# ── Voice clone sample (optional but makes voice sound completely real) ─────
# Record 6-10 seconds of clear speech in a quiet room, save as WAV
# Leave blank to use XTTS built-in speaker voice
VOICE_CLONE_WAV=

# ── YouTube OAuth2 ─────────────────────────────────────────────────────────
# credentials.json is placed in project root (not an env var)
# Guide: https://console.cloud.google.com → APIs → YouTube Data API v3
#        → Credentials → OAuth2 Desktop → Download as credentials.json
